{
  "name": "linkedlocke",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:env": "node scripts/validate-env.mjs",
    "verify": "npm run check:env && npm run lint && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:rules": "npx firebase-tools emulators:exec --project demo-linkedlocke-rules --only database \"vitest run --config vitest.rules.config.ts\"",
    "deploy:rules": "npx firebase-tools deploy --only database",
    "cleanup:runs": "npx firebase-tools database:remove /runs",
    "cleanup:runs:dev": "npx firebase-tools database:remove /runs --project linkedlocke-dev --instance linkedlocke-dev-default-rtdb"
  },
  "dependencies": {
    "firebase": "^12.10.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
